{
  "name": "delegate-registration-app",
  "version": "1.0.0",
  "description": "Full-stack delegate registration app with Razorpay payment integration",
  "main": "server/index.js",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "build-start": "npm run build && npm start"
  },
  "keywords": ["delegate", "registration", "razorpay", "payment"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "sql.js": "^1.10.3",
    "razorpay": "^2.9.2",
    "json2csv": "^6.0.0-alpha.2",
    "nodemailer": "^8.0.5",
    "exceljs": "^4.4.0",
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
